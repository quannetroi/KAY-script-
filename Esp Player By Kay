    local sg = Instance.new("ScreenGui")
    sg.Parent = LocalPlayer:WaitForChild("PlayerGui")
    sg.ResetOnSpawn = false
    
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0, 280, 0, 70)
    frame.Position = UDim2.new(0.5, -140, 0.08, 0)
    frame.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
    frame.BorderSizePixel = 0
    frame.Parent = sg
    
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 12)
    
    local stroke = Instance.new("UIStroke", frame)
    stroke.Color = Color3.fromRGB(90, 100, 255)
    stroke.Thickness = 1.5
    stroke.Transparency = 0.4
    
    local titleLabel = Instance.new("TextLabel", frame)
    titleLabel.Size = UDim2.new(1,0,0.4,0)
    titleLabel.BackgroundTransparency = 1
    titleLabel.Text = title
    titleLabel.TextColor3 = Color3.fromRGB(200, 200, 255)
    titleLabel.Font = Enum.Font.GothamBold
    titleLabel.TextSize = 16
    
    local textLabel = Instance.new("TextLabel", frame)
    textLabel.Size = UDim2.new(1,0,0.6,0)
    textLabel.Position = UDim2.new(0,0,0.4,0)
    textLabel.BackgroundTransparency = 1
    textLabel.Text = text
    textLabel.TextColor3 = Color3.fromRGB(220, 220, 220)
    textLabel.Font = Enum.Font.Gotham
    textLabel.TextSize = 14
    
    game:GetService("Debris"):AddItem(sg, duration or 3)
end

--esp creation
local function createPlayerESP(player)
    if player == LocalPlayer then return end
    
    local function setup(character)
        local hrp = character:WaitForChild("HumanoidRootPart", 8)
        if not hrp then return end
        
        local bb = Instance.new("BillboardGui")
        bb.Name = "esp"
        bb.Adornee = hrp
        bb.Size = UDim2.new(0, 180, 0, 60)
        bb.StudsOffset = Vector3.new(0, 3.2, 0)
        bb.AlwaysOnTop = true
        bb.Parent = hrp
        
        local f = Instance.new("Frame", bb)
        f.Size = UDim2.new(1,0,1,0)
        f.BackgroundColor3 = Color3.fromRGB(15,15,25)
        f.BackgroundTransparency = 0.65
        f.BorderSizePixel = 0
        
        Instance.new("UICorner", f).CornerRadius = UDim.new(0,10)
        
        local st = Instance.new("UIStroke", f)
        st.Color = Color3.fromRGB(100,110,255)
        st.Thickness = 1.2
        st.Transparency = 0.5
        
        local name = Instance.new("TextLabel", f)
        name.Size = UDim2.new(1,-10,0.55,0)
        name.Position = UDim2.new(0,5,0,5)
        name.BackgroundTransparency = 1
        name.Text = player.DisplayName or player.Name
        name.TextColor3 = Color3.fromRGB(240,240,255)
        name.TextStrokeTransparency = 0.7
        name.Font = Enum.Font.GothamBold
        name.TextScaled = true
        
        local dist = Instance.new("TextLabel", f)
        dist.Size = UDim2.new(1,-10,0.35,0)
        dist.Position = UDim2.new(0,5,0.6,0)
        dist.BackgroundTransparency = 1
        dist.TextColor3 = Color3.fromRGB(120,255,140)
        dist.TextStrokeTransparency = 0.8
        dist.Font = Enum.Font.Gotham
        dist.TextScaled = true
        
        local heartbeat = RunService.Heartbeat:Connect(function()
            if not playerESPEnabled then return end
            if not LocalPlayer.Character then return end
            local lhrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if not lhrp then return end
            local d = (hrp.Position - lhrp.Position).Magnitude
            dist.Text = math.floor(d + 0.5) .. " studs"
        end)
        
        table.insert(playerESPConnections, heartbeat)
    end
    
    if player.Character then task.spawn(setup, player.Character) end
    
    local charConn = player.CharacterAdded:Connect(function(char)
        if playerESPEnabled then
            task.wait(0.3)
            setup(char)
        end
    end)
    
    table.insert(playerESPConnections, charConn)
end

local function removeAllESP()
    for _, c in ipairs(playerESPConnections) do
        pcall(function() c:Disconnect() end)
    end
    playerESPConnections = {}
    
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Character then
            local hrp = p.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                local esp = hrp:FindFirstChild("esp")
                if esp then esp:Destroy() end
            end
        end
    end
end

--logic
local function toggleESP()
    playerESPEnabled = not playerESPEnabled
    
    if playerESPEnabled then
        for _, p in ipairs(Players:GetPlayers()) do
            createPlayerESP(p)
        end
        
        
        if not playerAddedConnection then
            playerAddedConnection = Players.PlayerAdded:Connect(function(p)
                if playerESPEnabled then
                    createPlayerESP(p)
                end
            end)
            table.insert(playerESPConnections, playerAddedConnection)
        end
        
        notify("ESP", "ENABLED", 2.5)
    else
        removeAllESP()
        notify("ESP", "DISABLED", 2.5)
    end
end

